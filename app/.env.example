# 백엔드 주소. 하드코딩 금지 — 이 값을 .env 로 복사해서 쓴다.
# Expo 는 EXPO_PUBLIC_ 접두사가 붙은 변수만 앱 코드에서 읽는다.
#
# - 웹/에뮬레이터에서 로컬 백엔드로 테스트: http://localhost:8000
# - 실제 폰(Expo Go)에서 테스트: 폰과 같은 와이파이의 PC LAN IP 를 쓴다.
#   예) http://192.168.0.10:8000  ("localhost" 는 폰에선 폰 자신을 가리켜서 안 됨)
EXPO_PUBLIC_BACKEND_URL=http://localhost:8000

# ── 안경(웨어러블) 이미지 소스 ─────────────────────────────
# "mock" — 하드웨어 없이 가짜 이미지 (기본값, Expo Go 에서 동작)
# "meta" — 실제 Meta 안경 (네이티브 SDK, dev build 필요). app/SETUP.md 참고.
EXPO_PUBLIC_GLASSES_PROVIDER=mock

# Meta Wearables 앱 ID (JS 참고용). 개발자 모드면 비워둬도 됨. (SETUP.md 2단계)
EXPO_PUBLIC_META_WEARABLES_APP_ID=

# 네이티브(안드로이드 매니페스트) 주입용 인증값. EXPO_PUBLIC_ 아님 → JS 번들에
# 노출되지 않고 app.config.js 가 dev build 때 매니페스트에만 넣는다.
# 개발자 모드면 비워두면 "0" 으로 주입된다. (SETUP.md 1~2단계)
META_WEARABLES_APPLICATION_ID=
META_WEARABLES_CLIENT_TOKEN=
